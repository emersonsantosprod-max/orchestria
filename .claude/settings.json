{
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(python -m ruff *)",
      "Bash(python -m app.main *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m ruff *)",
      "Bash(git *)",
      "Bash(make *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(sqlite3 *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(awk *)",
      "Bash(npm *)",
      "Bash(pyinstaller *)",
      "Bash(bash *)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:api.anthropic.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit-domain.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-py.sh"
          }
        ]
      }
    ]
  }
}
